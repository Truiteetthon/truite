<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Rémi Bonin</title>
    <link href="/Style.css" rel="stylesheet">
  </head>
  <body>

{{ content }}

<header>
  <a href="/index.html"><b>Rémi Bonin</b></a>

  <p>Type</p>
  {{ for cat of search.values("categorie").sort() }}
    <input type="radio" id="{{ cat }}" name="categorie" value="{{ cat }}">
    <label for="{{ cat }}">{{ cat }}</label><br>
  {{ /for }}

  <p>Pratique</p>
  {{ for pratique of search.values("pratique").sort() }}
    <input type="radio" id="{{ pratique }}" name="pratique" value="{{ pratique }}">
    <label for="{{ pratique }}">{{ pratique }}</label><br>
  {{ /for }}

  <p>Document</p>
  {{ set allDocuments = [] }}
  {{ for post of search.pages("tag=projet") }}
    {{ for doc of (post.documents ?? []) }}
      {{ for docType of (doc.document ?? []) }}
        {{ if !allDocuments.includes(docType) }}
          {{ set allDocuments = [...allDocuments, docType] }}
        {{ /if }}
      {{ /for }}
    {{ /for }}
  {{ /for }}
  {{ for document of allDocuments.sort() }}
    <input type="radio" id="{{ document }}" name="document" value="{{ document }}">
    <label for="{{ document }}">{{ document }}</label><br>
  {{ /for }}

  <p>Année</p>
  {{ for année of search.values("année").sort().reverse() }}
    <input type="radio" id="{{ année }}" name="year" value="{{ année }}">
    <label for="{{ année }}">{{ année }}</label><br>
  {{ /for }}

  <p>Lieu</p>
  {{ for lieu of search.values("lieu").sort() }}
    <input type="radio" id="{{ lieu }}" name="lieu" value="{{ lieu }}">
    <label for="{{ lieu }}">{{ lieu }}</label><br>
  {{ /for }}
</header>


<script src="/Script.js"></script>
  </body>
</html>
